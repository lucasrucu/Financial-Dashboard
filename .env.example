# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Anthropic
ANTHROPIC_API_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Exchange Rate (optional override — base URL only, no path or query string)
# Correct:   https://api.frankfurter.app
# Incorrect: https://api.frankfurter.app/latest?from=USD&to=PEN
EXCHANGE_RATE_API_URL=https://api.frankfurter.app

# BCP PDF statement password (typically your DNI)
BCP_PDF_PASSWORD=

# Resend — sends "Request Access" notifications to the operator.
# Get a key at https://resend.com (free tier). Without it, requests are still
# saved to the access_requests table; only the email notification is skipped.
RESEND_API_KEY=
# Where access-request emails are sent (defaults to the operator's address).
ACCESS_REQUEST_NOTIFY_EMAIL=
# Optional verified sender once you own a domain (defaults to onboarding@resend.dev).
RESEND_FROM=
